PORT=8080

# MySQL connection (host "db" matches the docker-compose service name)
DB_URL=jdbc:mysql://db:3306/vialreport?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USER=vialreport
DB_PASSWORD=vialreport_pass

# JWT — change secret to a long random string in production
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ISSUER=vialreport-api
JWT_AUDIENCE=vialreport-client
