PORT=8080

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# JWT — change secret to a long random string in production
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ISSUER=vialreport-api
JWT_AUDIENCE=vialreport-client

# Google Gemini (photo AI filter)
GEMINI_API_KEY=

# Upload directory for photos
UPLOAD_DIR=./uploads
